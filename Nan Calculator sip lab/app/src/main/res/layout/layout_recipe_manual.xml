<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/manual_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_background"
    android:backgroundTint="@color/oat_milk"
    android:padding="32dp">

    <View
        android:id="@+id/handle"
        android:layout_width="40dp"
        android:layout_height="5dp"
        android:background="@drawable/pearl_shape"
        android:backgroundTint="@color/red_wine"
        android:alpha="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/manual_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-black"
        android:text="The Barista's Mastery Guide"
        android:textColor="@color/red_wine"
        android:textSize="26sp"
        android:alpha="0"
        android:translationY="20dp"
        app:layout_constraintTop_toBottomOf="@id/handle"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/steps_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/manual_title">

        <LinearLayout
            android:id="@+id/step_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            android:alpha="0"
            android:translationX="-30dp">
            <TextView android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/pearl_shape" android:backgroundTint="@color/red_wine" android:gravity="center" android:text="1" android:textColor="@color/white" android:textStyle="bold" android:textSize="20sp"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="20dp" android:fontFamily="sans-serif-medium" android:text="Pick exactly 3 base flavors from the laboratory grid." android:textColor="@color/black" android:textSize="17sp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            android:alpha="0"
            android:translationX="-30dp">
            <TextView android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/pearl_shape" android:backgroundTint="@color/red_wine" android:gravity="center" android:text="2" android:textColor="@color/white" android:textStyle="bold" android:textSize="20sp"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="20dp" android:fontFamily="sans-serif-medium" android:text="Add 1 topping (Pearls, Jelly, or Choco) to bind the soul." android:textColor="@color/black" android:textSize="17sp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/step_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            android:alpha="0"
            android:translationX="-30dp">
            <TextView android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/pearl_shape" android:backgroundTint="@color/red_wine" android:gravity="center" android:text="3" android:textColor="@color/white" android:textStyle="bold" android:textSize="20sp"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="20dp" android:fontFamily="sans-serif-medium" android:text="Hit 'MIX' to manifest the ultimate Boba Alchemy!" android:textColor="@color/black" android:textSize="17sp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_manual"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="I AM READY"
        android:textColor="@color/red_wine"
        android:textSize="16sp"
        android:textStyle="bold"
        android:alpha="0"
        app:backgroundTint="@color/blush"
        app:cornerRadius="20dp"
        app:strokeColor="@color/black"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/steps_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>