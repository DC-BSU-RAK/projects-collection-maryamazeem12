<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#80000000">
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="oval">
                    <solid android:color="#D87A8D" />
                    <stroke android:width="5dp" android:color="@color/black" />
                </shape>
            </item>
            <item android:state_focused="true">
                <shape android:shape="oval">
                    <solid android:color="#E19DAA" />
                    <stroke android:width="4.5dp" android:color="@color/black" />
                </shape>
            </item>
            <item>
                <shape android:shape="oval">
                    <solid android:color="@color/blush" />
                    <stroke android:width="3.5dp" android:color="@color/black" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>