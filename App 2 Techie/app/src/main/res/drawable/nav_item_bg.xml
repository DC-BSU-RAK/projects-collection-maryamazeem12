<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state (Pushed down effect) -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="8dp" android:left="3dp" android:right="3dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#9C9488" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <item android:bottom="2dp" android:top="6dp">
                <shape android:shape="rectangle">
                    <solid android:color="#F2EDE4" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Default state (Elevated puffy effect) -->
    <item>
        <layer-list>
            <!-- Shadow Layer (Bottom depth) -->
            <item android:top="10dp" android:left="3dp" android:right="3dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#BAB2A6" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <!-- Top puffy surface -->
            <item android:bottom="8dp" android:top="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF" />
                    <corners android:radius="20dp" />
                    <stroke android:width="1dp" android:color="#F5F5F5" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>