<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Top Bar -->
    <ImageView
        android:id="@+id/logo_small"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:src="@drawable/logo"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Logo" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="serif"
        android:text="Edit Profile"
        android:textColor="@color/black"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_settings"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_margin="12dp"
        android:src="@drawable/settings"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Settings" />

    <!-- Profile Picture Section -->
    <FrameLayout
        android:id="@+id/profile_container"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_profile_pic"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/profilepic"
            app:shapeAppearanceOverlay="@style/CircleShape"
            android:background="@drawable/hover_circle_selector" />

        <ImageView
            android:id="@+id/btn_change_pic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="10dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/positivesign"
            android:background="@drawable/hover_circle_selector"
            android:padding="8dp"
            android:visibility="visible"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

    <!-- Info Form Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/form_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/form_bg_with_border"
        android:padding="32dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
        app:layout_constraintTop_toBottomOf="@id/profile_container">

        <EditText
            android:id="@+id/et_fullname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="@color/white"
            android:hint="Full name"
            android:padding="12dp"
            android:textColor="@color/white"
            android:textColorHint="#BBBBBB"
            android:inputType="textPersonName"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/white"
            android:hint="Email"
            android:padding="12dp"
            android:textColor="@color/white"
            android:textColorHint="#BBBBBB"
            android:inputType="textEmailAddress"
            app:layout_constraintTop_toBottomOf="@id/et_fullname" />

        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/white"
            android:hint="Username"
            android:padding="12dp"
            android:textColor="@color/white"
            android:textColorHint="#BBBBBB"
            android:inputType="text"
            app:layout_constraintTop_toBottomOf="@id/et_email" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/white"
            android:hint="Password"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textColor="@color/white"
            android:textColorHint="#BBBBBB"
            app:layout_constraintTop_toBottomOf="@id/et_username" />

        <ImageView
            android:id="@+id/btn_save_changes"
            android:layout_width="240dp"
            android:layout_height="65dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/savechangesbtn"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_password" />

        <ImageView
            android:id="@+id/btn_logout"
            android:layout_width="160dp"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/logoutbtn"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_save_changes" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Navigation -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/nav_bar_bg"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="15dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/nav_home"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/home"
                android:contentDescription="Home" />

            <ImageView
                android:id="@+id/nav_fav"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/favorites"
                android:contentDescription="Favorites" />

            <ImageView
                android:id="@+id/nav_cart"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/cart"
                android:contentDescription="Cart" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/nav_profile"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/nav_item_bg"
                android:padding="3dp"
                android:scaleType="centerCrop"
                android:src="@drawable/account"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:contentDescription="Profile" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>