<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_green">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Header with Image -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:background="@color/dark_green">

                <ImageView
                    android:id="@+id/logo_small"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_margin="16dp"
                    android:src="@drawable/logo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="Logo" />

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:padding="8dp"
                    android:src="@drawable/forwardbtn"
                    android:rotation="180"
                    android:background="@drawable/circle_bg"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/logo_small"
                    android:contentDescription="Back" />

                <ImageView
                    android:id="@+id/btn_settings_info"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_margin="16dp"
                    android:src="@drawable/settings"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="Settings" />

                <ImageView
                    android:id="@+id/iv_product_large"
                    android:layout_width="300dp"
                    android:layout_height="220dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/speaker2"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_back" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Product Details Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/splash_bg"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_info_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="Audio Physic Classic 3 Speaker Pair"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_info_variant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Wood Brown"
                    android:textColor="#666666"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_info_name" />

                <TextView
                    android:id="@+id/tv_info_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AED 3,664.00"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_info_name" />

                <LinearLayout
                    android:id="@+id/delivery_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_info_variant">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery in "
                        android:textColor="@color/black"
                        android:textSize="18sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="@color/black" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_delivery_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 days"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/delivery_container" />

                <!-- Quantity Selector -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/product_item_bg"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="4dp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_delivery_days"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/delivery_container">

                    <ImageView
                        android:id="@+id/btn_plus"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:background="@color/orange"
                        android:padding="8dp"
                        android:src="@drawable/positivesign" />

                    <TextView
                        android:id="@+id/tv_quantity"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btn_minus"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:background="@color/orange"
                        android:padding="8dp"
                        android:src="@drawable/negativesign" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/speaker2info"
                    app:layout_constraintTop_toBottomOf="@id/tv_delivery_days" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    app:layout_constraintTop_toBottomOf="@id/iv_details" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:background="@drawable/nav_bar_bg"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="15dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/nav_home"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/home"
                android:contentDescription="Home" />

            <ImageView
                android:id="@+id/nav_fav"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/favorites"
                android:contentDescription="Favorites" />

            <ImageView
                android:id="@+id/nav_cart"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/cart"
                android:contentDescription="Cart" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/nav_profile"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="3dp"
                android:scaleType="centerCrop"
                android:src="@drawable/account"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:contentDescription="Profile" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>