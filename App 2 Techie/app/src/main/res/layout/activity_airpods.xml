<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Top Bar -->
    <ImageView
        android:id="@+id/logo_small"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_margin="16dp"
        android:src="@drawable/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Logo" />

    <ImageView
        android:id="@+id/btn_settings"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="12dp"
        android:src="@drawable/settings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Settings" />

    <!-- User Header -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_user_profile"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/profilepic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo_small"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="3dp" />

    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Welcome! Name"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_user_profile"
        app:layout_constraintStart_toEndOf="@id/iv_user_profile"
        app:layout_constraintTop_toTopOf="@id/iv_user_profile" />

    <!-- Heading -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="serif"
        android:text="Airpods"
        android:textColor="@color/black"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/iv_user_profile"
        app:layout_constraintTop_toBottomOf="@id/iv_user_profile" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Your Device"
        android:textColor="#333333"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="@id/tv_title"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Category Buttons Row -->
    <HorizontalScrollView
        android:id="@+id/category_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

        <LinearLayout
            android:id="@+id/category_btns_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <Button
                android:id="@+id/btn_cat_headset"
                style="@style/OrangeButtonStyle"
                android:text="Headset" />

            <Button
                android:id="@+id/btn_cat_speakers"
                style="@style/OrangeButtonStyle"
                android:text="Speakers" />

            <Button
                android:id="@+id/btn_cat_smartwatch"
                style="@style/OrangeButtonStyle"
                android:text="Smart Watch" />

            <Button
                android:id="@+id/btn_cat_macbook"
                style="@style/OrangeButtonStyle"
                android:text="Macbook" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Product List -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
        app:layout_constraintTop_toBottomOf="@id/category_scroll">

        <LinearLayout
            android:id="@+id/product_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <include
                android:id="@+id/product1"
                layout="@layout/item_product" />

            <include
                android:id="@+id/product2"
                layout="@layout/item_product" />

            <include
                android:id="@+id/product3"
                layout="@layout/item_product" />

            <include
                android:id="@+id/product4"
                layout="@layout/item_product" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:background="@drawable/nav_bar_bg"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="15dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/nav_home"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/home"
                android:contentDescription="Home" />

            <ImageView
                android:id="@+id/nav_fav"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/favorites"
                android:contentDescription="Favorites" />

            <ImageView
                android:id="@+id/nav_cart"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="12dp"
                android:src="@drawable/cart"
                android:contentDescription="Cart" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/nav_profile"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/nav_item_bg"
                android:padding="3dp"
                android:scaleType="centerCrop"
                android:src="@drawable/account"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:contentDescription="Profile" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>